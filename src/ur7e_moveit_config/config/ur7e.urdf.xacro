<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ur7e">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import ur7e urdf file -->
    <xacro:include filename="$(find mybot_description)/urdf/ur7e.urdf" />

    <!-- Import control_xacro -->
    <xacro:include filename="ur7e.ros2_control.xacro" />


    <xacro:ur7e_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
